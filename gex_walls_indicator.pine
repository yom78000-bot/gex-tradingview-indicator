// GEX Walls Indicator (Multi-Symbol Universal) - Auto-généré le 2026-03-26 13:41:23
// Données du 2026-03-25 19:55:04
// Source : Base de données MySQL GEX
// Symboles supportés : SPY

//@version=5
indicator("GEX Walls (Multi-Symbol)", overlay=true, max_lines_count=500)

// ==================== PARAMÈTRES ====================
show_call_walls = input.bool(true, "Afficher Call Walls (Résistances)", group="Affichage")
show_put_walls = input.bool(true, "Afficher Put Walls (Supports)", group="Affichage")
show_labels = input.bool(true, "Afficher Labels", group="Affichage")
extend_lines = input.string("right", "Extension lignes", options=["none", "right", "both"], group="Affichage")

// Styles
call_color_1 = input.color(color.new(color.red, 0), "Call Wall #1", group="Couleurs")
call_color_2 = input.color(color.new(color.red, 40), "Call Wall #2", group="Couleurs")
call_color_3 = input.color(color.new(color.red, 60), "Call Wall #3", group="Couleurs")

put_color_1 = input.color(color.new(color.green, 0), "Put Wall #1", group="Couleurs")
put_color_2 = input.color(color.new(color.green, 40), "Put Wall #2", group="Couleurs")
put_color_3 = input.color(color.new(color.green, 60), "Put Wall #3", group="Couleurs")

// ==================== DÉTECTION SYMBOLE ====================
// Nettoyer le ticker pour enlever les préfixes (NYSE:, NASDAQ:, BATS:, etc.)
current_symbol = str.replace(syminfo.tickerid, "NYSE:", "")
current_symbol := str.replace(current_symbol, "NASDAQ:", "")
current_symbol := str.replace(current_symbol, "AMEX:", "")
current_symbol := str.replace(current_symbol, "CBOE:", "")
current_symbol := str.replace(current_symbol, "BATS:", "")

// ==================== DONNÉES GEX PAR SYMBOLE ====================

// SPY - Prix: $656.78 - Màj: 2026-03-25 19:55
var float spy_call_wall_1 = 660.00  // GEX: 19,662,563
var float spy_call_gex_1 = 19.7  // 19.7M
var float spy_call_wall_2 = 666.00  // GEX: 6,454,470
var float spy_call_gex_2 = 6.5  // 6.5M
var float spy_call_wall_3 = 659.00  // GEX: 6,133,380
var float spy_call_gex_3 = 6.1  // 6.1M
var float spy_put_wall_1 = 655.00  // GEX: -94,199,712
var float spy_put_gex_1 = 94.2  // 94.2M
var float spy_put_wall_2 = 650.00  // GEX: -57,900,653
var float spy_put_gex_2 = 57.9  // 57.9M
var float spy_put_wall_3 = 645.00  // GEX: -11,585,249
var float spy_put_gex_3 = 11.6  // 11.6M

// ==================== SÉLECTION WALLS SELON SYMBOLE ====================
call_wall_1 = current_symbol == "SPY" ? spy_call_wall_1 : na

call_wall_2 = current_symbol == "SPY" ? spy_call_wall_2 : na

call_wall_3 = current_symbol == "SPY" ? spy_call_wall_3 : na

put_wall_1 = current_symbol == "SPY" ? spy_put_wall_1 : na

put_wall_2 = current_symbol == "SPY" ? spy_put_wall_2 : na

put_wall_3 = current_symbol == "SPY" ? spy_put_wall_3 : na

// Valeurs GEX en millions
call_gex_1 = current_symbol == "SPY" ? spy_call_gex_1 : na

put_gex_1 = current_symbol == "SPY" ? spy_put_gex_1 : na

call_gex_2 = current_symbol == "SPY" ? spy_call_gex_2 : na

put_gex_2 = current_symbol == "SPY" ? spy_put_gex_2 : na

call_gex_3 = current_symbol == "SPY" ? spy_call_gex_3 : na

put_gex_3 = current_symbol == "SPY" ? spy_put_gex_3 : na


// ==================== VWAP ====================
vwap_value = ta.vwap(hlc3)
plot(vwap_value, title="VWAP", color=color.new(color.yellow, 30), linewidth=2, style=plot.style_line)

// ==================== DESSIN DES LIGNES ====================

// Fonction pour déterminer la taille du label selon la puissance GEX
get_label_size(gex_value) =>
    if gex_value > 80
        size.huge
    else if gex_value > 50
        size.large
    else if gex_value > 30
        size.normal
    else if gex_value > 15
        size.small
    else
        size.tiny

// Supprimer les anciennes lignes à chaque mise à jour
var line[] call_lines = array.new_line()
var line[] put_lines = array.new_line()

if barstate.islast
    // Supprimer les anciennes lignes
    for l in call_lines
        line.delete(l)
    for l in put_lines
        line.delete(l)
    array.clear(call_lines)
    array.clear(put_lines)

    // Dessiner les nouvelles lignes UNIQUEMENT si symbole supporté (très fines avec opacité)
    if not na(call_wall_1)
        // Call Walls - lignes fines transparentes
        if show_call_walls and not na(call_wall_1)
            array.push(call_lines, line.new(bar_index - 1, call_wall_1, bar_index, call_wall_1, color=color.new(call_color_1, 85), width=1, extend=extend.both))
        if show_call_walls and not na(call_wall_2)
            array.push(call_lines, line.new(bar_index - 1, call_wall_2, bar_index, call_wall_2, color=color.new(call_color_2, 85), width=1, extend=extend.both))
        if show_call_walls and not na(call_wall_3)
            array.push(call_lines, line.new(bar_index - 1, call_wall_3, bar_index, call_wall_3, color=color.new(call_color_3, 85), width=1, extend=extend.both))

        // Put Walls - lignes fines transparentes
        if show_put_walls and not na(put_wall_1)
            array.push(put_lines, line.new(bar_index - 1, put_wall_1, bar_index, put_wall_1, color=color.new(put_color_1, 85), width=1, extend=extend.both))
        if show_put_walls and not na(put_wall_2)
            array.push(put_lines, line.new(bar_index - 1, put_wall_2, bar_index, put_wall_2, color=color.new(put_color_2, 85), width=1, extend=extend.both))
        if show_put_walls and not na(put_wall_3)
            array.push(put_lines, line.new(bar_index - 1, put_wall_3, bar_index, put_wall_3, color=color.new(put_color_3, 85), width=1, extend=extend.both))

// Labels proportionnels à la puissance GEX (décalés de 10 barres)
if barstate.islast and show_labels and not na(call_wall_1)
    // Labels Call Walls - taille proportionnelle à la puissance
    if show_call_walls and not na(call_gex_1)
        label.new(bar_index + 10, call_wall_1, "$" + str.tostring(call_wall_1, "#.##") + " (" + str.tostring(call_gex_1, "#.#") + "M)",
                  color=color.new(call_color_1, 60), textcolor=color.white,
                  style=label.style_label_down, size=get_label_size(call_gex_1))
    if show_call_walls and not na(call_gex_2)
        label.new(bar_index + 10, call_wall_2, "$" + str.tostring(call_wall_2, "#.##") + " (" + str.tostring(call_gex_2, "#.#") + "M)",
                  color=color.new(call_color_2, 60), textcolor=color.white,
                  style=label.style_label_down, size=get_label_size(call_gex_2))
    if show_call_walls and not na(call_gex_3)
        label.new(bar_index + 10, call_wall_3, "$" + str.tostring(call_wall_3, "#.##") + " (" + str.tostring(call_gex_3, "#.#") + "M)",
                  color=color.new(call_color_3, 60), textcolor=color.white,
                  style=label.style_label_down, size=get_label_size(call_gex_3))

    // Labels Put Walls - taille proportionnelle à la puissance
    if show_put_walls and not na(put_gex_1)
        label.new(bar_index + 10, put_wall_1, "$" + str.tostring(put_wall_1, "#.##") + " (" + str.tostring(put_gex_1, "#.#") + "M)",
                  color=color.new(put_color_1, 60), textcolor=color.white,
                  style=label.style_label_up, size=get_label_size(put_gex_1))
    if show_put_walls and not na(put_gex_2)
        label.new(bar_index + 10, put_wall_2, "$" + str.tostring(put_wall_2, "#.##") + " (" + str.tostring(put_gex_2, "#.#") + "M)",
                  color=color.new(put_color_2, 60), textcolor=color.white,
                  style=label.style_label_up, size=get_label_size(put_gex_2))
    if show_put_walls and not na(put_gex_3)
        label.new(bar_index + 10, put_wall_3, "$" + str.tostring(put_wall_3, "#.##") + " (" + str.tostring(put_gex_3, "#.#") + "M)",
                  color=color.new(put_color_3, 60), textcolor=color.white,
                  style=label.style_label_up, size=get_label_size(put_gex_3))

// Message si symbole non supporté
if barstate.islast and na(call_wall_1)
    label.new(bar_index, close, "GEX non disponible pour " + current_symbol,
              color=color.orange, textcolor=color.white,
              style=label.style_label_center, size=size.normal)

// ==================== ZONE DE STABILITÉ ====================
// Les plot() doivent être au niveau global (pas dans un if)
top_wall = not na(call_wall_1) ? call_wall_1 : na
bottom_wall = not na(put_wall_1) ? put_wall_1 : na

plot_top = plot(top_wall, color=color.new(color.white, 100), display=display.none, title="Top Wall")
plot_bottom = plot(bottom_wall, color=color.new(color.white, 100), display=display.none, title="Bottom Wall")
fill(plot_top, plot_bottom, color=color.new(color.gray, 90), title="Zone de stabilité")

// ==================== TABLE INFO ====================
var table info_table = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80))

if barstate.islast and not na(call_wall_1)
    table.cell(info_table, 0, 0, "GEX Walls", text_color=color.white, text_size=size.normal)
    table.cell(info_table, 1, 0, current_symbol, text_color=color.yellow, text_size=size.normal)

    table.cell(info_table, 0, 1, "Call Wall #1", text_color=color.red)
    table.cell(info_table, 1, 1, "$" + str.tostring(call_wall_1, "#.##"), text_color=color.red)

    table.cell(info_table, 0, 2, "Put Wall #1", text_color=color.green)
    table.cell(info_table, 1, 2, "$" + str.tostring(put_wall_1, "#.##"), text_color=color.green)

    current_price = close
    status = current_price > top_wall ? "⚠️ AU-DESSUS" : current_price < bottom_wall ? "⚠️ EN-DESSOUS" : "✓ STABILITÉ"
    status_color = current_price > top_wall ? color.red : current_price < bottom_wall ? color.green : color.yellow
    table.cell(info_table, 0, 3, "Status", text_color=color.white)
    table.cell(info_table, 1, 3, status, text_color=status_color)
