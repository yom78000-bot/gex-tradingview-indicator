// QQQ - Prix: $584.00 - Màj: 2026-03-26 14:19
var float qqq_call_wall_1 = 590.00  // GEX: 25,000,000
var float qqq_call_gex_1 = 25.0  // 25.0M
var float qqq_call_wall_2 = 595.00  // GEX: 12,000,000
var float qqq_call_gex_2 = 12.0  // 12.0M
var float qqq_call_wall_3 = 588.00  // GEX: 10,000,000
var float qqq_call_gex_3 = 10.0  // 10.0M
var float qqq_put_wall_1 = 580.00  // GEX: -80,000,000
var float qqq_put_gex_1 = 80.0  // 80.0M
var float qqq_put_wall_2 = 575.00  // GEX: -45,000,000
var float qqq_put_gex_2 = 45.0  // 45.0M
