// GEX Walls Indicator (Multi-Symbol + Multi-Expiration) - Auto-généré le 2026-03-26 14:51:22
// Données du 2026-03-26 14:50:26
// Source : Base de données MySQL GEX
// Symboles supportés : AAPL, AMZN, DIA, IBIT, QQQ, SPY
// Expirations : 0DTE, Weekly, Monthly

//@version=5
indicator("GEX Walls (Multi-Symbol + Multi-Expiration)", overlay=true, max_lines_count=500)

// ==================== PARAMÈTRES ====================
expiration_select = input.string("Weekly", "Type d'expiration", options=["0DTE", "Weekly", "Monthly"], group="Expiration", tooltip="0DTE = expiration du jour, Weekly = ~7 jours, Monthly = ~30 jours")

show_call_walls = input.bool(true, "Afficher Call Walls (Résistances)", group="Affichage")
show_put_walls = input.bool(true, "Afficher Put Walls (Supports)", group="Affichage")
show_labels = input.bool(true, "Afficher Labels", group="Affichage")
extend_lines = input.string("right", "Extension lignes", options=["none", "right", "both"], group="Affichage")

// Styles (Call = vert, Put = rouge)
call_color_1 = input.color(color.new(color.green, 0), "Call Wall #1", group="Couleurs")
call_color_2 = input.color(color.new(color.green, 40), "Call Wall #2", group="Couleurs")
call_color_3 = input.color(color.new(color.green, 60), "Call Wall #3", group="Couleurs")

put_color_1 = input.color(color.new(color.red, 0), "Put Wall #1", group="Couleurs")
put_color_2 = input.color(color.new(color.red, 40), "Put Wall #2", group="Couleurs")
put_color_3 = input.color(color.new(color.red, 60), "Put Wall #3", group="Couleurs")

// ==================== DÉTECTION SYMBOLE ====================
// Nettoyer le ticker pour enlever les préfixes (NYSE:, NASDAQ:, BATS:, etc.)
current_symbol = str.replace(syminfo.tickerid, "NYSE:", "")
current_symbol := str.replace(current_symbol, "NASDAQ:", "")
current_symbol := str.replace(current_symbol, "AMEX:", "")
current_symbol := str.replace(current_symbol, "CBOE:", "")
current_symbol := str.replace(current_symbol, "BATS:", "")

// ==================== DONNÉES GEX PAR SYMBOLE ====================
// NOTE: Toutes les expirations affichent actuellement les données WEEKLY
// Le support complet 0DTE/Weekly/Monthly sera ajouté prochainement


// AAPL - Prix: $256.24 - Exp: 2026-04-02 (6j)
var float aapl_call_wall_1 = 257.50  // GEX: 4,824,289
var float aapl_call_gex_1 = 4.8  // 4.8M
var float aapl_call_wall_2 = 260.00  // GEX: 3,282,341
var float aapl_call_gex_2 = 3.3  // 3.3M
var float aapl_call_wall_3 = 262.50  // GEX: 2,331,015
var float aapl_call_gex_3 = 2.3  // 2.3M
var float aapl_put_wall_1 = 250.00  // GEX: -1,694,367
var float aapl_put_gex_1 = 1.7  // 1.7M

// AMZN - Prix: $212.40 - Exp: 2026-04-02 (6j)
var float amzn_call_wall_1 = 215.00  // GEX: 9,862,064
var float amzn_call_gex_1 = 9.9  // 9.9M
var float amzn_call_wall_2 = 217.50  // GEX: 3,265,146
var float amzn_call_gex_2 = 3.3  // 3.3M
var float amzn_call_wall_3 = 212.50  // GEX: 2,559,079
var float amzn_call_gex_3 = 2.6  // 2.6M
var float amzn_put_wall_1 = 207.50  // GEX: -246,137
var float amzn_put_gex_1 = 0.2  // 0.2M

// DIA - Prix: $463.85 - Exp: 2026-04-02 (6j)
var float dia_call_wall_1 = 470.00  // GEX: 423,422
var float dia_call_gex_1 = 0.4  // 0.4M
var float dia_call_wall_2 = 469.00  // GEX: 335,978
var float dia_call_gex_2 = 0.3  // 0.3M
var float dia_call_wall_3 = 474.00  // GEX: 280,941
var float dia_call_gex_3 = 0.3  // 0.3M
var float dia_put_wall_1 = 458.00  // GEX: -574,754
var float dia_put_gex_1 = 0.6  // 0.6M
var float dia_put_wall_2 = 459.00  // GEX: -559,715
var float dia_put_gex_2 = 0.6  // 0.6M
var float dia_put_wall_3 = 455.00  // GEX: -449,562
var float dia_put_gex_3 = 0.4  // 0.4M

// IBIT - Prix: $39.36 - Exp: 2026-04-02 (6j)
var float ibit_call_wall_1 = 40.00  // GEX: 2,079,132
var float ibit_call_gex_1 = 2.1  // 2.1M
var float ibit_put_wall_1 = 39.00  // GEX: -3,551,627
var float ibit_put_gex_1 = 3.6  // 3.6M
var float ibit_put_wall_2 = 39.50  // GEX: -1,792,081
var float ibit_put_gex_2 = 1.8  // 1.8M
var float ibit_put_wall_3 = 38.50  // GEX: -675,058
var float ibit_put_gex_3 = 0.7  // 0.7M

// QQQ - Prix: $581.67 - Exp: 2026-04-02 (6j)
var float qqq_call_wall_1 = 589.00  // GEX: 2,704,888
var float qqq_call_gex_1 = 2.7  // 2.7M
var float qqq_call_wall_2 = 593.00  // GEX: 567,972
var float qqq_call_gex_2 = 0.6  // 0.6M
var float qqq_call_wall_3 = 585.00  // GEX: 353,969
var float qqq_call_gex_3 = 0.4  // 0.4M
var float qqq_put_wall_1 = 590.00  // GEX: -14,141,269
var float qqq_put_gex_1 = 14.1  // 14.1M
var float qqq_put_wall_2 = 580.00  // GEX: -10,344,361
var float qqq_put_gex_2 = 10.3  // 10.3M
var float qqq_put_wall_3 = 575.00  // GEX: -9,132,132
var float qqq_put_gex_3 = 9.1  // 9.1M

// SPY - Prix: $652.52 - Exp: 2026-04-02 (6j)
var float spy_call_wall_1 = 663.00  // GEX: 6,980,591
var float spy_call_gex_1 = 7.0  // 7.0M
var float spy_call_wall_2 = 656.00  // GEX: 2,200,799
var float spy_call_gex_2 = 2.2  // 2.2M
var float spy_call_wall_3 = 661.00  // GEX: 1,414,344
var float spy_call_gex_3 = 1.4  // 1.4M
var float spy_put_wall_1 = 640.00  // GEX: -170,117,622
var float spy_put_gex_1 = 170.1  // 170.1M
var float spy_put_wall_2 = 650.00  // GEX: -68,156,291
var float spy_put_gex_2 = 68.2  // 68.2M
var float spy_put_wall_3 = 657.00  // GEX: -45,301,176
var float spy_put_gex_3 = 45.3  // 45.3M

// ==================== SÉLECTION WALLS SELON SYMBOLE ====================
call_wall_1 = current_symbol == "AAPL" ? aapl_call_wall_1 :
              current_symbol == "AMZN" ? amzn_call_wall_1 :
              current_symbol == "DIA" ? dia_call_wall_1 :
              current_symbol == "IBIT" ? ibit_call_wall_1 :
              current_symbol == "QQQ" ? qqq_call_wall_1 :
              current_symbol == "SPY" ? spy_call_wall_1 : na

call_wall_2 = current_symbol == "AAPL" ? aapl_call_wall_2 :
              current_symbol == "AMZN" ? amzn_call_wall_2 :
              current_symbol == "DIA" ? dia_call_wall_2 :
              current_symbol == "IBIT" ? ibit_call_wall_2 :
              current_symbol == "QQQ" ? qqq_call_wall_2 :
              current_symbol == "SPY" ? spy_call_wall_2 : na

call_wall_3 = current_symbol == "AAPL" ? aapl_call_wall_3 :
              current_symbol == "AMZN" ? amzn_call_wall_3 :
              current_symbol == "DIA" ? dia_call_wall_3 :
              current_symbol == "IBIT" ? ibit_call_wall_3 :
              current_symbol == "QQQ" ? qqq_call_wall_3 :
              current_symbol == "SPY" ? spy_call_wall_3 : na

put_wall_1 = current_symbol == "AAPL" ? aapl_put_wall_1 :
             current_symbol == "AMZN" ? amzn_put_wall_1 :
             current_symbol == "DIA" ? dia_put_wall_1 :
             current_symbol == "IBIT" ? ibit_put_wall_1 :
             current_symbol == "QQQ" ? qqq_put_wall_1 :
             current_symbol == "SPY" ? spy_put_wall_1 : na

put_wall_2 = current_symbol == "AAPL" ? aapl_put_wall_2 :
             current_symbol == "AMZN" ? amzn_put_wall_2 :
             current_symbol == "DIA" ? dia_put_wall_2 :
             current_symbol == "IBIT" ? ibit_put_wall_2 :
             current_symbol == "QQQ" ? qqq_put_wall_2 :
             current_symbol == "SPY" ? spy_put_wall_2 : na

put_wall_3 = current_symbol == "AAPL" ? aapl_put_wall_3 :
             current_symbol == "AMZN" ? amzn_put_wall_3 :
             current_symbol == "DIA" ? dia_put_wall_3 :
             current_symbol == "IBIT" ? ibit_put_wall_3 :
             current_symbol == "QQQ" ? qqq_put_wall_3 :
             current_symbol == "SPY" ? spy_put_wall_3 : na

// Valeurs GEX en millions
call_gex_1 = current_symbol == "AAPL" ? aapl_call_gex_1 :
              current_symbol == "AMZN" ? amzn_call_gex_1 :
              current_symbol == "DIA" ? dia_call_gex_1 :
              current_symbol == "IBIT" ? ibit_call_gex_1 :
              current_symbol == "QQQ" ? qqq_call_gex_1 :
              current_symbol == "SPY" ? spy_call_gex_1 : na

put_gex_1 = current_symbol == "AAPL" ? aapl_put_gex_1 :
              current_symbol == "AMZN" ? amzn_put_gex_1 :
              current_symbol == "DIA" ? dia_put_gex_1 :
              current_symbol == "IBIT" ? ibit_put_gex_1 :
              current_symbol == "QQQ" ? qqq_put_gex_1 :
              current_symbol == "SPY" ? spy_put_gex_1 : na

call_gex_2 = current_symbol == "AAPL" ? aapl_call_gex_2 :
              current_symbol == "AMZN" ? amzn_call_gex_2 :
              current_symbol == "DIA" ? dia_call_gex_2 :
              current_symbol == "IBIT" ? ibit_call_gex_2 :
              current_symbol == "QQQ" ? qqq_call_gex_2 :
              current_symbol == "SPY" ? spy_call_gex_2 : na

put_gex_2 = current_symbol == "AAPL" ? aapl_put_gex_2 :
              current_symbol == "AMZN" ? amzn_put_gex_2 :
              current_symbol == "DIA" ? dia_put_gex_2 :
              current_symbol == "IBIT" ? ibit_put_gex_2 :
              current_symbol == "QQQ" ? qqq_put_gex_2 :
              current_symbol == "SPY" ? spy_put_gex_2 : na

call_gex_3 = current_symbol == "AAPL" ? aapl_call_gex_3 :
              current_symbol == "AMZN" ? amzn_call_gex_3 :
              current_symbol == "DIA" ? dia_call_gex_3 :
              current_symbol == "IBIT" ? ibit_call_gex_3 :
              current_symbol == "QQQ" ? qqq_call_gex_3 :
              current_symbol == "SPY" ? spy_call_gex_3 : na

put_gex_3 = current_symbol == "AAPL" ? aapl_put_gex_3 :
              current_symbol == "AMZN" ? amzn_put_gex_3 :
              current_symbol == "DIA" ? dia_put_gex_3 :
              current_symbol == "IBIT" ? ibit_put_gex_3 :
              current_symbol == "QQQ" ? qqq_put_gex_3 :
              current_symbol == "SPY" ? spy_put_gex_3 : na


// ==================== VWAP ====================
vwap_value = ta.vwap(hlc3)
plot(vwap_value, title="VWAP", color=color.new(color.yellow, 30), linewidth=2, style=plot.style_line)

// ==================== DESSIN DES LIGNES ====================

// Fonction pour déterminer l'épaisseur de la ligne selon la puissance GEX
get_line_width(gex_value) =>
    if gex_value > 80
        4
    else if gex_value > 50
        3
    else if gex_value > 30
        2
    else
        1

// Fonction pour déterminer l'opacité de la ligne selon la puissance GEX
get_line_opacity(gex_value) =>
    if gex_value > 80
        60  // Plus visible pour walls très forts
    else if gex_value > 50
        65
    else if gex_value > 30
        70
    else
        75  // Plus transparent pour walls faibles

// Fonction pour ajouter du padding (largeur) au label selon la puissance GEX
get_label_padding(gex_value) =>
    if gex_value > 80
        "━━━━━━━━━━━━━━━━━━━━"  // Très large
    else if gex_value > 50
        "━━━━━━━━━━━━━━"  // Large
    else if gex_value > 30
        "━━━━━━━━━"  // Moyen
    else if gex_value > 15
        "━━━━━"  // Petit
    else
        "━━"  // Très petit

// Supprimer les anciennes lignes et labels à chaque mise à jour
var line[] call_lines = array.new_line()
var line[] put_lines = array.new_line()
var label[] call_labels = array.new_label()
var label[] put_labels = array.new_label()

if barstate.islast
    // Supprimer les anciennes lignes
    for l in call_lines
        line.delete(l)
    for l in put_lines
        line.delete(l)
    array.clear(call_lines)
    array.clear(put_lines)

    // Supprimer les anciens labels pour éviter le chevauchement de texte
    for lbl in call_labels
        label.delete(lbl)
    for lbl in put_labels
        label.delete(lbl)
    array.clear(call_labels)
    array.clear(put_labels)

    // Dessiner les nouvelles lignes UNIQUEMENT si symbole supporté (épaisseur et opacité proportionnelles)
    if not na(call_wall_1)
        // Call Walls - épaisseur et opacité selon puissance
        if show_call_walls and not na(call_wall_1)
            array.push(call_lines, line.new(bar_index - 1, call_wall_1, bar_index, call_wall_1, color=color.new(call_color_1, get_line_opacity(call_gex_1)), width=get_line_width(call_gex_1), extend=extend.both))
        if show_call_walls and not na(call_wall_2)
            array.push(call_lines, line.new(bar_index - 1, call_wall_2, bar_index, call_wall_2, color=color.new(call_color_2, get_line_opacity(call_gex_2)), width=get_line_width(call_gex_2), extend=extend.both))
        if show_call_walls and not na(call_wall_3)
            array.push(call_lines, line.new(bar_index - 1, call_wall_3, bar_index, call_wall_3, color=color.new(call_color_3, get_line_opacity(call_gex_3)), width=get_line_width(call_gex_3), extend=extend.both))

        // Put Walls - épaisseur et opacité selon puissance
        if show_put_walls and not na(put_wall_1)
            array.push(put_lines, line.new(bar_index - 1, put_wall_1, bar_index, put_wall_1, color=color.new(put_color_1, get_line_opacity(put_gex_1)), width=get_line_width(put_gex_1), extend=extend.both))
        if show_put_walls and not na(put_wall_2)
            array.push(put_lines, line.new(bar_index - 1, put_wall_2, bar_index, put_wall_2, color=color.new(put_color_2, get_line_opacity(put_gex_2)), width=get_line_width(put_gex_2), extend=extend.both))
        if show_put_walls and not na(put_wall_3)
            array.push(put_lines, line.new(bar_index - 1, put_wall_3, bar_index, put_wall_3, color=color.new(put_color_3, get_line_opacity(put_gex_3)), width=get_line_width(put_gex_3), extend=extend.both))

    // Gamma Flip (Zero Gamma Level) - Entre Call Wall #1 et Put Wall #1
    if not na(call_wall_1) and not na(put_wall_1)
        gamma_flip = (call_wall_1 + put_wall_1) / 2
        array.push(call_lines, line.new(bar_index - 1, gamma_flip, bar_index, gamma_flip,
                  color=color.new(color.orange, 50), width=2, extend=extend.both, style=line.style_dashed))

        if show_labels
            array.push(call_labels, label.new(bar_index + 20, gamma_flip, " GAMMA FLIP $" + str.tostring(gamma_flip, "#.##") + " ━━━━━━━━━━",
                      color=color.new(color.orange, 40), textcolor=color.white,
                      style=label.style_label_left, size=size.normal))

    // Labels compacts (moins hauts) mais plus larges selon puissance GEX (tous alignés verticalement par la gauche)
    if show_labels and not na(call_wall_1)
        // Labels Call Walls - tous alignés verticalement par le bord gauche
        if show_call_walls and not na(call_gex_1)
            array.push(call_labels, label.new(bar_index + 20, call_wall_1, " $" + str.tostring(call_wall_1, "#.##") + " (" + str.tostring(call_gex_1, "#.#") + "M) " + get_label_padding(call_gex_1),
                      color=color.new(call_color_1, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))
        if show_call_walls and not na(call_gex_2)
            array.push(call_labels, label.new(bar_index + 20, call_wall_2, " $" + str.tostring(call_wall_2, "#.##") + " (" + str.tostring(call_gex_2, "#.#") + "M) " + get_label_padding(call_gex_2),
                      color=color.new(call_color_2, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))
        if show_call_walls and not na(call_gex_3)
            array.push(call_labels, label.new(bar_index + 20, call_wall_3, " $" + str.tostring(call_wall_3, "#.##") + " (" + str.tostring(call_gex_3, "#.#") + "M) " + get_label_padding(call_gex_3),
                      color=color.new(call_color_3, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))

        // Labels Put Walls - tous alignés verticalement par le bord gauche (même style que Call)
        if show_put_walls and not na(put_gex_1)
            array.push(put_labels, label.new(bar_index + 20, put_wall_1, " $" + str.tostring(put_wall_1, "#.##") + " (" + str.tostring(put_gex_1, "#.#") + "M) " + get_label_padding(put_gex_1),
                      color=color.new(put_color_1, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))
        if show_put_walls and not na(put_gex_2)
            array.push(put_labels, label.new(bar_index + 20, put_wall_2, " $" + str.tostring(put_wall_2, "#.##") + " (" + str.tostring(put_gex_2, "#.#") + "M) " + get_label_padding(put_gex_2),
                      color=color.new(put_color_2, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))
        if show_put_walls and not na(put_gex_3)
            array.push(put_labels, label.new(bar_index + 20, put_wall_3, " $" + str.tostring(put_wall_3, "#.##") + " (" + str.tostring(put_gex_3, "#.#") + "M) " + get_label_padding(put_gex_3),
                      color=color.new(put_color_3, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))

// Message si symbole non supporté
if barstate.islast and na(call_wall_1)
    label.new(bar_index, close, "GEX non disponible pour " + current_symbol,
              color=color.orange, textcolor=color.white,
              style=label.style_label_center, size=size.normal)

// ==================== ZONE DE STABILITÉ ====================
// Les plot() doivent être au niveau global (pas dans un if)
top_wall = not na(call_wall_1) ? call_wall_1 : na
bottom_wall = not na(put_wall_1) ? put_wall_1 : na

plot_top = plot(top_wall, color=color.new(color.white, 100), display=display.none, title="Top Wall")
plot_bottom = plot(bottom_wall, color=color.new(color.white, 100), display=display.none, title="Bottom Wall")
fill(plot_top, plot_bottom, color=color.new(color.gray, 90), title="Zone de stabilité")

// ==================== TABLE INFO ====================
var table info_table = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80))

if barstate.islast and not na(call_wall_1)
    table.cell(info_table, 0, 0, "GEX Walls", text_color=color.white, text_size=size.normal)
    table.cell(info_table, 1, 0, current_symbol, text_color=color.yellow, text_size=size.normal)

    table.cell(info_table, 0, 1, "Call Wall #1", text_color=color.red)
    table.cell(info_table, 1, 1, "$" + str.tostring(call_wall_1, "#.##"), text_color=color.red)

    table.cell(info_table, 0, 2, "Put Wall #1", text_color=color.green)
    table.cell(info_table, 1, 2, "$" + str.tostring(put_wall_1, "#.##"), text_color=color.green)

    current_price = close
    status = current_price > top_wall ? "⚠️ AU-DESSUS" : current_price < bottom_wall ? "⚠️ EN-DESSOUS" : "✓ STABILITÉ"
    status_color = current_price > top_wall ? color.red : current_price < bottom_wall ? color.green : color.yellow
    table.cell(info_table, 0, 3, "Status", text_color=color.white)
    table.cell(info_table, 1, 3, status, text_color=status_color)
