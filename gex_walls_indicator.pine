// GEX Walls Indicator (Multi-Symbol + Multi-Expiration) - Auto-généré le 2026-03-26 15:42:17
// Données du 2026-03-26 15:41:40
// Source : Base de données MySQL GEX
// Symboles supportés : AAPL, AMZN, DIA, IBIT, QQQ, SPY
// Expirations : 0DTE, Weekly, Monthly

//@version=5
indicator("GEX Walls (Multi-Symbol + Multi-Expiration)", overlay=true, max_lines_count=500)

// ==================== PARAMÈTRES ====================
expiration_select = input.string("1st week (7d)", "Type d'expiration", options=["0DTE (0d)", "1st week (7d)", "2nd week (14d)", "1st month (30d)", "all"], group="Expiration", tooltip="0DTE = expiration du jour, 1st week = ~7j, 2nd week = ~14j, 1st month = ~30j, all = toutes les expirations")

show_call_walls = input.bool(true, "Afficher Call Walls (Résistances)", group="Affichage")
show_put_walls = input.bool(true, "Afficher Put Walls (Supports)", group="Affichage")
show_labels = input.bool(true, "Afficher Labels", group="Affichage")
extend_lines = input.string("right", "Extension lignes", options=["none", "right", "both"], group="Affichage")

// Styles (Call = vert, Put = rouge)
call_color_1 = input.color(color.new(color.green, 0), "Call Wall #1", group="Couleurs")
call_color_2 = input.color(color.new(color.green, 40), "Call Wall #2", group="Couleurs")
call_color_3 = input.color(color.new(color.green, 60), "Call Wall #3", group="Couleurs")

put_color_1 = input.color(color.new(color.red, 0), "Put Wall #1", group="Couleurs")
put_color_2 = input.color(color.new(color.red, 40), "Put Wall #2", group="Couleurs")
put_color_3 = input.color(color.new(color.red, 60), "Put Wall #3", group="Couleurs")

// ==================== DÉTECTION SYMBOLE ====================
// Nettoyer le ticker pour enlever les préfixes (NYSE:, NASDAQ:, BATS:, etc.)
current_symbol = str.replace(syminfo.tickerid, "NYSE:", "")
current_symbol := str.replace(current_symbol, "NASDAQ:", "")
current_symbol := str.replace(current_symbol, "AMEX:", "")
current_symbol := str.replace(current_symbol, "CBOE:", "")
current_symbol := str.replace(current_symbol, "BATS:", "")

