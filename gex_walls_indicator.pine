// ==================== VWAP ====================
vwap_value = ta.vwap(hlc3)
plot(vwap_value, title="VWAP", color=color.new(color.yellow, 30), linewidth=2, style=plot.style_line)

// ==================== DESSIN DES LIGNES ====================

// Fonction pour déterminer l'épaisseur de la ligne selon la puissance GEX
get_line_width(gex_value) =>
    if gex_value > 80
        4
    else if gex_value > 50
        3
    else if gex_value > 30
        2
    else
        1

// Fonction pour déterminer l'opacité de la ligne selon la puissance GEX
get_line_opacity(gex_value) =>
    if gex_value > 80
        60  // Plus visible pour walls très forts
    else if gex_value > 50
        65
    else if gex_value > 30
        70
    else
        75  // Plus transparent pour walls faibles

// Fonction pour ajouter du padding (largeur) au label selon la puissance GEX
get_label_padding(gex_value) =>
    if gex_value > 80
        "━━━━━━━━━━━━━━━━━━━━"  // Très large
    else if gex_value > 50
        "━━━━━━━━━━━━━━"  // Large
    else if gex_value > 30
        "━━━━━━━━━"  // Moyen
    else if gex_value > 15
        "━━━━━"  // Petit
    else
        "━━"  // Très petit

// Supprimer les anciennes lignes et labels à chaque mise à jour
var line[] call_lines = array.new_line()
var line[] put_lines = array.new_line()
var label[] call_labels = array.new_label()
var label[] put_labels = array.new_label()

if barstate.islast
    // Supprimer les anciennes lignes
    for l in call_lines
        line.delete(l)
    for l in put_lines
        line.delete(l)
    array.clear(call_lines)
    array.clear(put_lines)

    // Supprimer les anciens labels pour éviter le chevauchement de texte
    for lbl in call_labels
        label.delete(lbl)
    for lbl in put_labels
        label.delete(lbl)
    array.clear(call_labels)
    array.clear(put_labels)

    // Dessiner les nouvelles lignes UNIQUEMENT si symbole supporté (épaisseur et opacité proportionnelles)
    if not na(call_wall_1)
        // Call Walls - épaisseur et opacité selon puissance
        if show_call_walls and not na(call_wall_1)
            array.push(call_lines, line.new(bar_index - 1, call_wall_1, bar_index, call_wall_1, color=color.new(call_color_1, get_line_opacity(call_gex_1)), width=get_line_width(call_gex_1), extend=extend.both))
        if show_call_walls and not na(call_wall_2)
            array.push(call_lines, line.new(bar_index - 1, call_wall_2, bar_index, call_wall_2, color=color.new(call_color_2, get_line_opacity(call_gex_2)), width=get_line_width(call_gex_2), extend=extend.both))
        if show_call_walls and not na(call_wall_3)
            array.push(call_lines, line.new(bar_index - 1, call_wall_3, bar_index, call_wall_3, color=color.new(call_color_3, get_line_opacity(call_gex_3)), width=get_line_width(call_gex_3), extend=extend.both))

        // Put Walls - épaisseur et opacité selon puissance
        if show_put_walls and not na(put_wall_1)
            array.push(put_lines, line.new(bar_index - 1, put_wall_1, bar_index, put_wall_1, color=color.new(put_color_1, get_line_opacity(put_gex_1)), width=get_line_width(put_gex_1), extend=extend.both))
        if show_put_walls and not na(put_wall_2)
            array.push(put_lines, line.new(bar_index - 1, put_wall_2, bar_index, put_wall_2, color=color.new(put_color_2, get_line_opacity(put_gex_2)), width=get_line_width(put_gex_2), extend=extend.both))
        if show_put_walls and not na(put_wall_3)
            array.push(put_lines, line.new(bar_index - 1, put_wall_3, bar_index, put_wall_3, color=color.new(put_color_3, get_line_opacity(put_gex_3)), width=get_line_width(put_gex_3), extend=extend.both))

    // Gamma Flip (Zero Gamma Level) - Entre Call Wall #1 et Put Wall #1
    if not na(call_wall_1) and not na(put_wall_1)
        gamma_flip = (call_wall_1 + put_wall_1) / 2
        array.push(call_lines, line.new(bar_index - 1, gamma_flip, bar_index, gamma_flip,
                  color=color.new(color.orange, 50), width=2, extend=extend.both, style=line.style_dashed))

        if show_labels
            array.push(call_labels, label.new(bar_index + 20, gamma_flip, " GAMMA FLIP $" + str.tostring(gamma_flip, "#.##") + " ━━━━━━━━━━",
                      color=color.new(color.orange, 40), textcolor=color.white,
                      style=label.style_label_left, size=size.normal))

    // Labels compacts (moins hauts) mais plus larges selon puissance GEX (tous alignés verticalement par la gauche)
    if show_labels and not na(call_wall_1)
        // Labels Call Walls - tous alignés verticalement par le bord gauche
        if show_call_walls and not na(call_gex_1)
            array.push(call_labels, label.new(bar_index + 20, call_wall_1, " $" + str.tostring(call_wall_1, "#.##") + " (" + str.tostring(call_gex_1, "#.#") + "M) " + get_label_padding(call_gex_1),
                      color=color.new(call_color_1, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))
        if show_call_walls and not na(call_gex_2)
            array.push(call_labels, label.new(bar_index + 20, call_wall_2, " $" + str.tostring(call_wall_2, "#.##") + " (" + str.tostring(call_gex_2, "#.#") + "M) " + get_label_padding(call_gex_2),
                      color=color.new(call_color_2, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))
        if show_call_walls and not na(call_gex_3)
            array.push(call_labels, label.new(bar_index + 20, call_wall_3, " $" + str.tostring(call_wall_3, "#.##") + " (" + str.tostring(call_gex_3, "#.#") + "M) " + get_label_padding(call_gex_3),
                      color=color.new(call_color_3, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))

        // Labels Put Walls - tous alignés verticalement par le bord gauche (même style que Call)
        if show_put_walls and not na(put_gex_1)
            array.push(put_labels, label.new(bar_index + 20, put_wall_1, " $" + str.tostring(put_wall_1, "#.##") + " (" + str.tostring(put_gex_1, "#.#") + "M) " + get_label_padding(put_gex_1),
                      color=color.new(put_color_1, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))
        if show_put_walls and not na(put_gex_2)
            array.push(put_labels, label.new(bar_index + 20, put_wall_2, " $" + str.tostring(put_wall_2, "#.##") + " (" + str.tostring(put_gex_2, "#.#") + "M) " + get_label_padding(put_gex_2),
                      color=color.new(put_color_2, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))
        if show_put_walls and not na(put_gex_3)
            array.push(put_labels, label.new(bar_index + 20, put_wall_3, " $" + str.tostring(put_wall_3, "#.##") + " (" + str.tostring(put_gex_3, "#.#") + "M) " + get_label_padding(put_gex_3),
                      color=color.new(put_color_3, 60), textcolor=color.white,
                      style=label.style_label_left, size=size.small))

// Message si symbole non supporté
if barstate.islast and na(call_wall_1)
    label.new(bar_index, close, "GEX non disponible pour " + current_symbol,
              color=color.orange, textcolor=color.white,
              style=label.style_label_center, size=size.normal)

// ==================== ZONE DE STABILITÉ ====================
// Les plot() doivent être au niveau global (pas dans un if)
top_wall = not na(call_wall_1) ? call_wall_1 : na
bottom_wall = not na(put_wall_1) ? put_wall_1 : na

plot_top = plot(top_wall, color=color.new(color.white, 100), display=display.none, title="Top Wall")
plot_bottom = plot(bottom_wall, color=color.new(color.white, 100), display=display.none, title="Bottom Wall")
fill(plot_top, plot_bottom, color=color.new(color.gray, 90), title="Zone de stabilité")

// ==================== TABLE INFO ====================
var table info_table = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80))

if barstate.islast and not na(call_wall_1)
    table.cell(info_table, 0, 0, "GEX Walls", text_color=color.white, text_size=size.normal)
    table.cell(info_table, 1, 0, current_symbol, text_color=color.yellow, text_size=size.normal)

    table.cell(info_table, 0, 1, "Call Wall #1", text_color=color.red)
    table.cell(info_table, 1, 1, "$" + str.tostring(call_wall_1, "#.##"), text_color=color.red)

    table.cell(info_table, 0, 2, "Put Wall #1", text_color=color.green)
    table.cell(info_table, 1, 2, "$" + str.tostring(put_wall_1, "#.##"), text_color=color.green)

    current_price = close
    status = current_price > top_wall ? "⚠️ AU-DESSUS" : current_price < bottom_wall ? "⚠️ EN-DESSOUS" : "✓ STABILITÉ"
    status_color = current_price > top_wall ? color.red : current_price < bottom_wall ? color.green : color.yellow
    table.cell(info_table, 0, 3, "Status", text_color=color.white)
    table.cell(info_table, 1, 3, status, text_color=status_color)
